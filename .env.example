# Environment Variables Configuration
# Copy this file to .env and fill in your credentials
# Command: copy .env.example .env (Windows) or cp .env.example .env (Linux/Mac)

# ============================================================================
# GMAIL CREDENTIALS (REQUIRED for email automation)
# ============================================================================
# Get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Factor Authentication
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate app password for "Mail"
# 5. Use the 16-character password below (no spaces)

EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Note: Use App Password, NOT your regular Gmail password!
# App Password format: 16 characters, may have spaces (remove them)


# ============================================================================
# LINKEDIN CREDENTIALS (OPTIONAL - for LinkedIn posting)
# ============================================================================
# Warning: Using automation may violate LinkedIn Terms of Service
# Recommendation: Use a test account, not your main account

LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_SESSION_PATH=./AI_Employee_Vault/Logs/sessions/linkedin_session.json

# After first successful login, session is saved and password not needed


# ============================================================================
# TWITTER/X CREDENTIALS (OPTIONAL - for Twitter posting)
# ============================================================================

TWITTER_EMAIL=your_email@gmail.com
TWITTER_PASSWORD=your_twitter_password
TWITTER_SESSION_PATH=./AI_Employee_Vault/Logs/sessions/twitter_session.json


# ============================================================================
# FACEBOOK CREDENTIALS (OPTIONAL - for Facebook posting)
# ============================================================================

FACEBOOK_EMAIL=your_email@gmail.com
FACEBOOK_PASSWORD=your_facebook_password
FACEBOOK_SESSION_PATH=./AI_Employee_Vault/Logs/sessions/facebook_session.json


# ============================================================================
# INSTAGRAM CREDENTIALS (OPTIONAL - for Instagram posting)
# ============================================================================

INSTAGRAM_EMAIL=your_email@gmail.com
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_SESSION_PATH=./AI_Employee_Vault/Logs/sessions/instagram_session.json


# ============================================================================
# WHATSAPP (OPTIONAL - for WhatsApp monitoring and replies)
# ============================================================================
# No credentials needed! Uses QR code authentication
# Session saved automatically after first scan

WHATSAPP_SESSION_PATH=./AI_Employee_Vault/Logs/whatsapp_session.json

# First run: python scripts/whatsapp_watcher.py --once
# Scan QR code with your phone
# Session persists - no need to scan again!


# ============================================================================
# ANTHROPIC API (OPTIONAL - for Claude AI integration)
# ============================================================================
# Get API key from: https://console.anthropic.com/
# Note: Currently using template-based replies (no API needed)
# Uncomment below if you want to use Claude API for reply generation

# ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here


# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env file to git
# 2. .env is already in .gitignore
# 3. Use App Passwords for Gmail (not regular password)
# 4. Rotate credentials regularly
# 5. Use test accounts for social media automation
# 6. Monitor logs for suspicious activity


# ============================================================================
# SESSION FILES
# ============================================================================
# Session files are automatically created in:
# AI_Employee_Vault/Logs/sessions/
#
# These files store browser state (cookies, localStorage, etc.)
# so you don't need to login repeatedly
#
# Delete session file to force re-login:
# - LinkedIn: AI_Employee_Vault/Logs/sessions/linkedin_session.json
# - Twitter: AI_Employee_Vault/Logs/sessions/twitter_session.json
# - Facebook: AI_Employee_Vault/Logs/sessions/facebook_session.json
# - WhatsApp: AI_Employee_Vault/Logs/whatsapp_session.json


# ============================================================================
# QUICK START
# ============================================================================
# Minimum required for basic functionality:
# 1. EMAIL_ADDRESS
# 2. EMAIL_APP_PASSWORD
#
# Everything else is optional and can be added later!

