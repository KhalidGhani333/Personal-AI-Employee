# Environment Variables Configuration
# Copy this file to .env and fill in your credentials

# Gmail SMTP (for email sending)
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password

# Gmail IMAP (for email receiving)
# Use same credentials as SMTP

# Social Media (Session-based - No passwords needed!)
# Sessions are saved automatically after first login:
# - LinkedIn: AI_Employee_Vault/Logs/sessions/linkedin_session.json
# - Twitter: AI_Employee_Vault/Logs/sessions/twitter_session.json
# - Facebook: AI_Employee_Vault/Logs/sessions/facebook_session.json
# - WhatsApp: AI_Employee_Vault/Logs/whatsapp_session.json

# Note: Never commit .env file to git
# Add .env to .gitignore

