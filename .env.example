# Environment Variables Configuration
# Copy this file to .env: copy .env.example .env

# ============================================================================
# REQUIRED CREDENTIALS
# ============================================================================

# Gmail (Required for email automation)
# Get App Password: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password


# ============================================================================
# OPTIONAL CREDENTIALS (Add only if needed)
# ============================================================================

# LinkedIn
LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password

# Instagram
INSTAGRAM_EMAIL=your_email@gmail.com
INSTAGRAM_PASSWORD=your_password

# Twitter/X
TWITTER_EMAIL=your_email@gmail.com
TWITTER_PASSWORD=your_password

# Facebook
FACEBOOK_EMAIL=your_email@gmail.com
FACEBOOK_PASSWORD=your_password

# WhatsApp (No credentials needed - uses QR code)
# Run: python scripts/whatsapp_watcher.py --once

# Odoo Accounting (Optional)
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password

# Anthropic API (Optional)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key


# ============================================================================
# SECURITY
# ============================================================================
# - NEVER commit .env to git
# - Use Gmail App Password (not regular password)
# - Use test accounts for social media automation
