playwright-state.json

# Browser profiles (contain cookies and auth)
AI_Employee_Vault/Browser_Profiles/
Browser_Profiles/

# In_Progress folders (temporary working state - not synced)
AI_Employee_Vault/In_Progress/

# Dashboard lock file (temporary)
AI_Employee_Vault/.dashboard.lock

# Log files (too large, regenerated, may contain sensitive data)
logs/*.log
Logs/*.log
AI_Employee_Vault/Logs/*.log
.claude/agents/logs/*.log
mcp-servers/*/Logs/*.log
mcp-servers/**/Logs/*.log

# State and processed files (contain runtime data)
Logs/*.json
AI_Employee_Vault/Logs/*.json
AI_Employee_Vault/Logs/processed_*.json
*_state.json

# Accounting data (financial information)
AI_Employee_Vault/Accounting/*.json
AI_Employee_Vault/Accounting/transactions.json

# Keep vault structure but ignore specific sensitive files
# Note: We WANT to sync Inbox, Needs_Action, Needs_Approval, Done folders
# Only ignore sessions and large logs

